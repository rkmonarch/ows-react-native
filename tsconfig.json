{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationDir": "lib/typescript",
    "outDir": "lib/commonjs",
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "example", "backend"]
}
